# ==========================================
# PRODUCTION PROFILE — PostgreSQL on Azure
# Activate with: spring.profiles.active=prod (or SPRING_PROFILES_ACTIVE=prod)
# Copy to application-prod.properties (gitignored) and fill the environment vars.
# Overrides the dev/H2 values from application.properties.
# ==========================================

# ------------------------------------------
# DATABASE — Azure Database for PostgreSQL
# ------------------------------------------
spring.datasource.url=jdbc:postgresql://${DB_HOST}:${DB_PORT:5432}/${DB_NAME}?sslmode=require
spring.datasource.driverClassName=org.postgresql.Driver
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

# ------------------------------------------
# SCHEMA — Flyway is the single source of truth
# ------------------------------------------
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.properties.hibernate.type.preferred_enum_jdbc_type=VARCHAR
spring.flyway.enabled=true
spring.jpa.show-sql=false

# ------------------------------------------
# H2 console must never be exposed in production
# ------------------------------------------
spring.h2.console.enabled=false

# ------------------------------------------
# REQUIRED ENVIRONMENT VARIABLES (prod)
#   DB_HOST        Azure PostgreSQL host (e.g. my-server.postgres.database.azure.com)
#   DB_NAME        database name
#   DB_USERNAME    database user
#   DB_PASSWORD    database password
#   MAIL_PASSWORD  Gmail app password
#   JWT_SECRET     256-bit base64 signing key
# Optional:
#   DB_PORT        defaults to 5432
# ==========================================
